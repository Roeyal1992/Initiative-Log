{
  "name": "Initiative-log",
  "version": "1.0.0",
  "description": "Your Figma widget",
  "scripts": {
    "build": "esbuild widget-src/code.tsx --bundle --outfile=dist/code.js --target=es2017",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "tsc": "tsc --noEmit -p widget-src",
    "watch": "npm run build -- --watch",
    "preview:build": "esbuild preview/main.ts --bundle --outfile=preview/dist/preview.js --tsconfig=widget-src/tsconfig.json --target=es2017",
    "preview": "esbuild preview/main.ts --bundle --outfile=preview/dist/preview.js --tsconfig=widget-src/tsconfig.json --target=es2017 --servedir=preview --serve=8008"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@figma/widget-typings": "*",
    "esbuild": "*",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}